{
  "version": 2,
  "name": "dealer-sourcing-fullstack",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "https://dealer-sourcing-api.onrender.com"
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
