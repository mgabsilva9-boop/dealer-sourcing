{
  "version": 2,
  "name": "dealer-sourcing-fullstack",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "build": {
    "env": {
      "VITE_API_URL": "https://dealer-sourcing-api-production.up.railway.app"
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(?!assets|api)(.*)",
      "dest": "/index.html"
    }
  ]
}
