{
  "version": 2,
  "name": "dealer-sourcing-frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "https://dealer-sourcing-api.onrender.com"
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://dealer-sourcing-backend.onrender.com/api/$1",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
