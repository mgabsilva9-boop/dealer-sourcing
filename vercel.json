{
  "version": 2,
  "name": "dealer-sourcing-frontend",
  "builds": [
    {
      "src": "src/frontend/App.jsx",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url"
  }
}
